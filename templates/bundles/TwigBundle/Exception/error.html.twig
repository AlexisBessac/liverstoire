{% extends "base.html.twig" %}

{% block title %}{{ status_code }} - Erreur{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="alert alert-danger" role="alert">
                <h1 class="alert-heading">Erreur {{ status_code }}</h1>
                <hr>
                <p><strong>{{ status_text }}</strong></p>
                <p>{{ exception.message }}</p>
                
                {% if status_code == 404 %}
                    <hr>
                    <a href="{{ path('app_admin_periods_index') }}" class="btn btn-primary">Retour aux périodes</a>
                {% elseif status_code == 500 %}
                    <hr>
                    <p class="text-muted">Veuillez contacter l'administrateur si le problème persiste.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
